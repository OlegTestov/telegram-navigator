# === REQUIRED ===

# Telegram Bot API token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telethon — for reading channel history (get from https://my.telegram.org)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# Telethon session string (run: make session or python generate_session.py)
TELEGRAM_SESSION_STRING=

# Google Gemini API key (for classification & digests)
GEMINI_API_KEY=

# Your Telegram user ID (get from @userinfobot)
ADMIN_TELEGRAM_ID=

# === OPTIONAL ===

# Gemini model (default: gemini-3-flash-preview)
GEMINI_MODEL=gemini-3-flash-preview

# Database backend: "sqlite" (default, local) or "supabase"
DB_BACKEND=sqlite
SQLITE_DB_PATH=data/content_table.db

# Supabase (only if DB_BACKEND=supabase)
SUPABASE_URL=
SUPABASE_KEY=

# OpenAI embeddings (optional, for hybrid search)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pipeline
LOG_LEVEL=INFO
BATCH_SIZE=50
