# Telethon (channel reading)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_SESSION_STRING=

# Bot API
TELEGRAM_BOT_TOKEN=

# Gemini
GEMINI_API_KEY=
